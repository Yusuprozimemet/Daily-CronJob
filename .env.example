# Copy to .env and fill in. NEVER commit .env.
# In GitHub Actions these come from repo Settings > Secrets, not this file.

# NVIDIA API (GLM-5.1 summarizer)
NVIDIA_API_KEY=

# Email delivery (Gmail SMTP)
GMAIL_APP_PASSWORD=
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com

# Telegram delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Reddit needs no credentials — we read the public RSS feeds.

# Optional: raises GitHub API rate limit (not required for a few repos).
GITHUB_TOKEN=
